{
  "name": "ManifestGuard V5",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install -r requirements.txt && cd frontend && npm install",
  "postAttachCommand": {
    "backend": "python backend/serve.py",
    "frontend": "cd frontend && npm run dev"
  },
  "forwardPorts": [8000, 5173]
}