# ManifestGuard Backend Configuration
# Copy this file to .env and fill in your API keys

# AI Provider (choose one)
# Option A: Groq (recommended - fast and free)
GROQ_API_KEY=your_groq_api_key_here
# Option B: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# Option C: Custom OpenAI-compatible endpoint
MANIFESTGUARD_AI_API_KEY=your_key_here
MANIFESTGUARD_AI_BASE_URL=https://your-endpoint.com/v1
MANIFESTGUARD_AI_MODEL=your-model-name

# Threat Intelligence APIs (all optional, enables live domain scanning)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ALIENVAULT_OTX_KEY=your_otx_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here

# Server Configuration
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://your-extension-id
