{
  "manifest_version": 3,
  "name": "ManifestGuard Scanner",
  "version": "1.0.0",
  "description": "Companion extension for ManifestGuard — scans your installed extensions for security risks.",
  "permissions": ["management", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
